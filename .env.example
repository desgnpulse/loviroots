# Copy to .env and fill in values. Never commit .env.

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=   # 2547XXXXXXXX — no + prefix

# WordPress / WPGraphQL
WP_GRAPHQL_URL=                # https://cms.loviroots.com/graphql

# Pesapal (web checkout)
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_ENV=sandbox            # sandbox | production

# Brevo (marketing email)
BREVO_API_KEY=
BREVO_LIST_ID=                 # numeric list ID from Brevo dashboard

# Resend (transactional email)
RESEND_API_KEY=

# NextAuth (admin panel)
NEXTAUTH_SECRET=               # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Admin credentials
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=           # bcrypt hash — generate with: node -e "require('bcrypt').hash('pw',12).then(console.log)"
